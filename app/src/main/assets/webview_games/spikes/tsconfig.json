{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "target": "ES6",
    "module": "ES6",
    "moduleResolution": "node",
    "outDir": "./dist",
    "strict": false,
    "esModuleInterop": true,
    "lib": ["ES6", "ES2016", "DOM"]
  },
  "exclude": ["node_modules"],
  "include": [
    "./*.js",
    "./objects/**/*.js",
    "./scenes/**/*.js",
    "./types/**/*.d.ts"
  ]
}